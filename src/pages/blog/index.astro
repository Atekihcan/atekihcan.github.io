---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { postUrl } from '../../lib/slugs';

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allCategories = [...new Set(posts.flatMap((p) => p.data.categories))].sort();
---

<Base title="Blog" description="All blog posts">
  <h1>Blog</h1>

  <div class="categories">
    <a href="/blog/" class="active">All</a>
    {allCategories.map((cat) => <a href={`/blog/${cat}/`}>{cat}</a>)}
  </div>

  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <a href={postUrl(post)}>
            <div>
              <span class="post-title">{post.data.title}</span>
              {post.data.description && (
                <span class="post-desc">{post.data.description}</span>
              )}
            </div>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </a>
        </li>
      ))
    }
  </ul>
</Base>

<style>
  h1 {
    margin-bottom: 1rem;
  }

  .categories {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .categories a {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 0.25rem 0.75rem;
    border-radius: 3px;
    background: var(--bg-secondary);
    color: var(--text-muted);
  }

  .categories a.active,
  .categories a:hover {
    background: var(--accent);
    color: #fff;
    text-decoration: none;
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    gap: 1rem;
  }

  .post-list a:hover {
    text-decoration: none;
    color: var(--accent);
  }

  .post-title {
    font-weight: 500;
    display: block;
  }

  .post-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    display: block;
    margin-top: 0.2rem;
  }

  .post-list time {
    color: var(--text-muted);
    font-size: 0.85rem;
    white-space: nowrap;
  }
</style>
